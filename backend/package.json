{
  "name": "aeo-backend",
  "version": "1.0.0",
  "description": "AEO Platform — Node.js/Express backend",
  "main": "src/index.js",
  "scripts": {
    "dev":          "nodemon src/index.js",
    "start":        "npx prisma generate && npx prisma db push && node src/index.js",
    "postinstall":  "prisma generate && npx playwright install chromium --with-deps",
    "db:generate":  "prisma generate",
    "db:migrate":   "prisma migrate dev",
    "db:push":      "prisma db push",
    "db:studio":    "prisma studio",
    "db:seed":      "node prisma/seed.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^5.22.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "prisma": "^5.22.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
