# ── Database (Zeabur managed PostgreSQL) ──────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/aeo

# ── Cache (Zeabur managed Redis) ─────────────────────────────────────────────
REDIS_URL=redis://default:password@host:6379

# ── Anthropic Claude API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Platform settings ─────────────────────────────────────────────────────────
# Public hostname used in generated llms.txt URLs and sitemaps
PLATFORM_HOST=aeo.yourdomain.com

# URL of the Next.js frontend (used for CORS allow-list)
FRONTEND_URL=https://aeo.yourdomain.com

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
